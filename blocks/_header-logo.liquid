

{% liquid
  assign alt_text_fallback = shop.name | escape | append: ' — Home'
%}

{%- comment -%}
  Charlie Pike Tobacco — Split Navigation Header
  LEFT:   Cigarettes · Cigars · Tobacco
  CENTER: Brand logo (linked to home)
  RIGHT:  Glass Pipes · E-Cigs · & More
{%- endcomment -%}
<div
  class="size-style spacing-style header-logo gv-header-logo cp-split-nav"
  {{ block.shopify_attributes }}
>

  {%- comment -%} Left side — 3 categories {%- endcomment -%}
  <nav class="cp-split-nav__side cp-split-nav__side--left" aria-label="Shop categories">
    <a href="/collections/cigarettes" class="cp-split-nav__link">Cigarettes</a>
    <a href="/collections/cigars" class="cp-split-nav__link">Cigars</a>
    <a href="/collections/tobacco" class="cp-split-nav__link">Tobacco</a>
  </nav>

  {%- comment -%} Center — brand logo {%- endcomment -%}
  <a
    href="{{ routes.root_url }}"
    class="cp-split-nav__logo-link"
    aria-label="{{ shop.name }} — Home"
  >
    <img
      src="{{ 'SVG/Asset 4.png' | asset_url }}"
      alt="{{ shop.name }}"
      class="cp-split-nav__logo-img"
      width="200"
      height="80"
      loading="eager"
      decoding="async"
    >
  </a>

  {%- comment -%} Right side — 3 categories {%- endcomment -%}
  <nav class="cp-split-nav__side cp-split-nav__side--right" aria-label="More categories">
    <a href="/collections/glass-pipes" class="cp-split-nav__link">Glass Pipes</a>
    <a href="/collections/e-cigs" class="cp-split-nav__link">E-Cigs</a>
    <a href="/collections" class="cp-split-nav__link cp-split-nav__link--more">&amp; More</a>
  </nav>

</div>

{% stylesheet %}
  /* Base header-logo flex container — overridden for split nav in gv-custom.css */
  .header-logo {
    display: flex;
    height: 100%;
    align-items: center;
    text-decoration: none;

    &:hover {
      text-decoration: none;
    }

    @media screen and (max-width: 749px) {
      padding: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.logo",
  "tag": null,
  "class": "header-logo",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:content.edit_logo_in_theme_settings"
    },
    {
      "type": "header",
      "content": "t:content.padding_desktop"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
