        "custom_liquid": "<style>\n.cp-visit{text-align:center;position:relative;overflow:hidden}\n.cp-visit__bg{position:absolute;inset:0;background:url('https://static.where-e.com/United_States/Charlie-Pike-Tobacco_47304e39e6f45c113448877b5333e8e1.jpg') center/cover no-repeat;filter:brightness(.2) saturate(.65);z-index:0}\n.cp-visit__inner{position:relative;z-index:1;max-width:820px;margin:0 auto;padding:0 24px}\n.cp-visit__label{display:block;font-size:.65rem;letter-spacing:.32em;text-transform:uppercase;color:#C97A1A;margin-bottom:22px;font-weight:600}\n.cp-visit__title{font-size:clamp(2.8rem,7vw,6.5rem);font-weight:900;text-transform:uppercase;letter-spacing:-.04em;color:#f5f4f0;margin:0 0 24px;line-height:.9}\n.cp-visit__address{font-size:1rem;letter-spacing:.06em;text-transform:uppercase;color:rgba(245,244,240,.72);margin:0 0 8px;font-weight:500}\n.cp-visit__hours{font-size:.78rem;letter-spacing:.16em;text-transform:uppercase;color:#C97A1A;margin:0 0 20px;font-weight:700}\n.cp-visit__divider{width:60px;height:1px;background:rgba(201,122,26,.45);margin:0 auto 36px;display:block}\n.cp-visit__desc{font-size:.88rem;line-height:1.72;color:rgba(245,244,240,.58);margin:0 0 48px;max-width:520px;margin-left:auto;margin-right:auto}\n.cp-visit__btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}\n.cp-visit__btn{display:inline-block;padding:15px 34px;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;font-weight:700;text-decoration:none;border-radius:2px;transition:all .26s ease}\n.cp-visit__btn--primary{background:#C97A1A;color:#fff;border:1px solid #C97A1A}\n.cp-visit__btn--primary:hover{background:#a86014;border-color:#a86014;transform:translateY(-2px);box-shadow:0 12px 36px rgba(201,122,26,.38)}\n.cp-visit__btn--secondary{background:transparent;color:#f5f4f0;border:1px solid rgba(245,244,240,.32)}\n.cp-visit__btn--secondary:hover{background:rgba(245,244,240,.07);border-color:rgba(245,244,240,.55);transform:translateY(-2px)}\n</style>\n<div class=\"cp-visit\">\n  <div class=\"cp-visit__bg\"></div>\n  <div class=\"cp-visit__inner\">\n    <span class=\"cp-visit__label\">Come see us in person</span>\n    <h2 class=\"cp-visit__title\">Visit Us<br>In Seattle</h2>\n    <p class=\"cp-visit__address\">611 E Pike St, Seattle, WA 98122</p>\n    <p class=\"cp-visit__hours\">Open Daily &middot; 9:00 AM &ndash; 11:00 PM</p>\n    <span class=\"cp-visit__divider\"></span>\n    <p class=\"cp-visit__desc\">A vibrant destination for tobacco enthusiasts in the heart of Capitol Hill. Friendly staff, an exceptional range of products, and reasonable prices &mdash; everything you need, all in one place.</p>\n    <div class=\"cp-visit__btns\">\n      <a href=\"https://maps.google.com/?q=611+E+Pike+St+Seattle+WA+98122\" target=\"_blank\" class=\"cp-visit__btn cp-visit__btn--primary\">Get Directions</a>\n      <a href=\"/collections/all\" class=\"cp-visit__btn cp-visit__btn--secondary\">Shop Online</a>\n    </div>\n  </div>\n</div>",
