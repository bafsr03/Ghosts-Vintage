    "three_pillars": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n.cp-pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;width:100%}\n@media(max-width:749px){.cp-pillars{grid-template-columns:1fr}}\n.cp-pillar{position:relative;aspect-ratio:3/4;overflow:hidden;background:#111}\n.cp-pillar__img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .85s cubic-bezier(0,0,.18,1),filter .55s ease;filter:brightness(.48) saturate(.8)}\n.cp-pillar:hover .cp-pillar__img{transform:scale(1.07);filter:brightness(.36) saturate(.65)}\n.cp-pillar__body{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:32px 28px;background:linear-gradient(to top,rgba(8,8,8,.95) 0%,rgba(8,8,8,.45) 45%,transparent 100%)}\n.cp-pillar__num{font-size:.62rem;letter-spacing:.32em;text-transform:uppercase;color:#C97A1A;font-weight:700;margin-bottom:10px}\n.cp-pillar__title{font-size:1.65rem;font-weight:800;text-transform:uppercase;color:#f5f4f0;letter-spacing:.02em;margin:0 0 10px;line-height:1}\n.cp-pillar__desc{font-size:.78rem;line-height:1.62;color:rgba(245,244,240,.62);margin:0 0 16px;max-width:260px}\n.cp-pillar__link{display:inline-block;font-size:.6rem;letter-spacing:.24em;text-transform:uppercase;color:#C97A1A;text-decoration:none;font-weight:700;border-bottom:1px solid rgba(201,122,26,.4);padding-bottom:3px;transition:color .22s,border-color .22s}\n.cp-pillar:hover .cp-pillar__link{color:#fff;border-color:rgba(255,255,255,.38)}\n</style>\n<div class=\"cp-pillars\">\n  <div class=\"cp-pillar\">\n    <img src=\"https://static.where-e.com/United_States/Charlie-Pike-Tobacco_fd75bccfaa632b1ec213e7f8b82a8a69.jpg\" alt=\"The Selection\" class=\"cp-pillar__img\" loading=\"lazy\">\n    <div class=\"cp-pillar__body\">\n      <span class=\"cp-pillar__num\">01</span>\n      <h3 class=\"cp-pillar__title\">The Selection</h3>\n      <p class=\"cp-pillar__desc\">An unmatched range of premium cigarettes, cigars, and rolling tobacco curated for the true enthusiast.</p>\n      <a href=\"/collections/tobacco\" class=\"cp-pillar__link\">Shop Tobacco &rarr;</a>\n    </div>\n  </div>\n  <div class=\"cp-pillar\">\n    <img src=\"https://static.where-e.com/United_States/Charlie-Pike-Tobacco_a9e65a772924b3da7e148705cd8ac383.jpg\" alt=\"The Glass\" class=\"cp-pillar__img\" loading=\"lazy\">\n    <div class=\"cp-pillar__body\">\n      <span class=\"cp-pillar__num\">02</span>\n      <h3 class=\"cp-pillar__title\">The Glass</h3>\n      <p class=\"cp-pillar__desc\">American-made heady glass and handcrafted smoking accessories built to impress &mdash; one-of-a-kind pieces.</p>\n      <a href=\"/collections/glass-pipes\" class=\"cp-pillar__link\">Shop Glass &rarr;</a>\n    </div>\n  </div>\n  <div class=\"cp-pillar\">\n    <img src=\"https://static.where-e.com/United_States/Charlie-Pike-Tobacco_b8dc44e41ee966fae0440aafcada880d.jpg\" alt=\"The Gear\" class=\"cp-pillar__img\" loading=\"lazy\">\n    <div class=\"cp-pillar__body\">\n      <span class=\"cp-pillar__num\">03</span>\n      <h3 class=\"cp-pillar__title\">The Gear</h3>\n      <p class=\"cp-pillar__desc\">Top-tier vape mods, e-liquids, and accessories. Exceptional quality at prices that won&rsquo;t break the bank.</p>\n      <a href=\"/collections/e-cigs\" class=\"cp-pillar__link\">Shop E-Cigs &rarr;</a>\n    </div>\n  </div>\n</div>",
        "color_scheme": "scheme-1",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "about_band": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n.cp-about{display:grid;grid-template-columns:1fr 1fr;gap:0;min-height:520px}\n@media(max-width:749px){.cp-about{grid-template-columns:1fr}}\n.cp-about__img-wrap{position:relative;overflow:hidden;min-height:340px}\n.cp-about__img{width:100%;height:100%;object-fit:cover;display:block;filter:brightness(.65) saturate(.85);transition:transform 1.2s cubic-bezier(0,0,.18,1)}\n.cp-about__img-wrap:hover .cp-about__img{transform:scale(1.04)}\n.cp-about__img-overlay{position:absolute;inset:0;background:linear-gradient(to right,rgba(8,8,8,.6) 0%,rgba(8,8,8,.15) 100%)}\n.cp-about__content{background:#111111;padding:64px 56px;display:flex;flex-direction:column;justify-content:center}\n@media(max-width:749px){.cp-about__content{padding:44px 28px}}\n.cp-about__label{font-size:.62rem;letter-spacing:.35em;text-transform:uppercase;color:#C97A1A;font-weight:700;margin-bottom:20px;display:block}\n.cp-about__title{font-size:clamp(2rem,3.5vw,3.2rem);font-weight:800;text-transform:uppercase;letter-spacing:-.03em;color:#f5f4f0;margin:0 0 20px;line-height:1}\n.cp-about__title span{color:#C97A1A}\n.cp-about__body{font-size:.88rem;line-height:1.75;color:rgba(245,244,240,.62);margin:0 0 36px;max-width:460px}\n.cp-about__stats{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:36px}\n.cp-about__stat-val{font-size:1.6rem;font-weight:800;color:#C97A1A;line-height:1;display:block}\n.cp-about__stat-lbl{font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,244,240,.45);font-weight:600;display:block;margin-top:4px}\n.cp-about__btn{display:inline-block;padding:13px 32px;font-size:.68rem;letter-spacing:.2em;text-transform:uppercase;font-weight:700;color:#fff;background:#C97A1A;border:1px solid #C97A1A;border-radius:2px;text-decoration:none;transition:all .28s ease;align-self:flex-start}\n.cp-about__btn:hover{background:#a86014;border-color:#a86014;transform:translateY(-2px);box-shadow:0 10px 28px rgba(201,122,26,.35)}\n</style>\n<div class=\"cp-about\">\n  <div class=\"cp-about__img-wrap\">\n    <img src=\"https://static.where-e.com/United_States/Charlie-Pike-Tobacco_4535d7745778df06bd88eac5838c26a5.jpg\" alt=\"Inside Charlie Pike Tobacco\" class=\"cp-about__img\" loading=\"lazy\">\n    <div class=\"cp-about__img-overlay\"></div>\n  </div>\n  <div class=\"cp-about__content\">\n    <span class=\"cp-about__label\">Who We Are</span>\n    <h2 class=\"cp-about__title\">Seattle&rsquo;s <span>Finest</span><br>Tobacco Shop</h2>\n    <p class=\"cp-about__body\">Charlie Pike Tobacco is a vibrant destination for tobacco enthusiasts in Seattle. We offer an impressive selection of products &mdash; from American-made heady glass to premium vape mods, cigars, cigarettes, and beyond. Exceptional range. Reasonable prices. Friendly faces.</p>\n    <div class=\"cp-about__stats\">\n      <div>\n        <span class=\"cp-about__stat-val\">9AM</span>\n        <span class=\"cp-about__stat-lbl\">Opens Daily</span>\n      </div>\n      <div>\n        <span class=\"cp-about__stat-val\">11PM</span>\n        <span class=\"cp-about__stat-lbl\">Closes Daily</span>\n      </div>\n      <div>\n        <span class=\"cp-about__stat-val\">611</span>\n        <span class=\"cp-about__stat-lbl\">E Pike St, Seattle</span>\n      </div>\n      <div>\n        <span class=\"cp-about__stat-val\">★ 8.2</span>\n        <span class=\"cp-about__stat-lbl\">Product Variety</span>\n      </div>\n    </div>\n    <a href=\"/pages/about\" class=\"cp-about__btn\">Our Story</a>\n  </div>\n</div>",
