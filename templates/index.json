    "newsletter_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n.cp-newsletter{text-align:center;max-width:700px;margin:0 auto;padding:0 24px}\n.cp-newsletter__label{display:block;font-size:.65rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(245,244,240,.45);margin-bottom:20px}\n.cp-newsletter__title{font-size:clamp(2.2rem,5vw,4.2rem);font-weight:800;text-transform:uppercase;letter-spacing:-.02em;color:#f5f4f0;margin:0 0 10px;line-height:1}\n.cp-newsletter__title span{color:#C97A1A}\n.cp-newsletter__sub{font-size:.8rem;color:rgba(245,244,240,.48);letter-spacing:.08em;text-transform:uppercase;margin-bottom:40px}\n.cp-newsletter__form{display:flex;gap:0;max-width:500px;margin:0 auto;border:1px solid rgba(245,244,240,.18);border-radius:2px;overflow:hidden;transition:border-color .25s ease}\n.cp-newsletter__form:focus-within{border-color:#C97A1A}\n.cp-newsletter__input{flex:1;background:transparent;border:none;color:#f5f4f0;font-size:.82rem;letter-spacing:.07em;padding:16px 22px;outline:none;min-width:0}\n.cp-newsletter__input::placeholder{color:rgba(245,244,240,.3);text-transform:uppercase;letter-spacing:.1em}\n.cp-newsletter__btn{background:#C97A1A;color:#fff;border:none;font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;font-weight:700;padding:16px 26px;cursor:pointer;transition:background .22s ease;white-space:nowrap}\n.cp-newsletter__btn:hover{background:#a86014}\n.cp-divider{width:72px;height:2px;background:linear-gradient(90deg,#C97A1A,#E84C2B);margin:0 auto 40px;display:block;border-radius:1px}\n</style>\n<div class=\"cp-newsletter\">\n  <span class=\"cp-newsletter__label\">Stay connected</span>\n  <h2 class=\"cp-newsletter__title\">JOIN THE <span>PIKE</span></h2>\n  <p class=\"cp-newsletter__sub\">New arrivals. Deals. First access to drops.</p>\n  <span class=\"cp-divider\"></span>\n  <form class=\"cp-newsletter__form\" action=\"/contact#contact_form\" method=\"post\" accept-charset=\"UTF-8\">\n    <input type=\"hidden\" name=\"form_type\" value=\"customer\">\n    <input type=\"hidden\" name=\"utf8\" value=\"&#x2713;\">\n    <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter\">\n    <input class=\"cp-newsletter__input\" type=\"email\" name=\"contact[email]\" placeholder=\"Your email address\" required>\n    <button class=\"cp-newsletter__btn\" type=\"submit\">Subscribe</button>\n  </form>\n</div>",
