    "hero_custom": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n.gv-hero{\n  position:relative;\n  min-height:100svh;\n  display:flex;\n  flex-direction:column;\n  align-items:center;\n  justify-content:center;\n  overflow:hidden;\n  background:#080808;\n}\n.gv-hero__bg{\n  position:absolute;inset:0;z-index:0;\n  background:linear-gradient(to bottom,rgba(8,8,8,0.3) 0%,rgba(8,8,8,0.15) 40%,rgba(8,8,8,0.75) 80%,#080808 100%);\n}\n.gv-hero__bg-img{\n  position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:-1;\n  filter:brightness(0.5) saturate(0.65);\n}\n.gv-hero__body{\n  position:relative;z-index:1;\n  display:flex;\n  flex-direction:column;\n  align-items:center;\n  text-align:center;\n  padding:0 24px;\n  gap:0;\n  animation:gv-body-in 1s cubic-bezier(0,0,0.18,1) 0.3s both;\n}\n@keyframes gv-body-in{\n  from{opacity:0;transform:translateY(28px);}\n  to{opacity:1;transform:translateY(0);}\n}\n.gv-hero__icon{\n  width:320px;height:320px;\n  object-fit:contain;\n  margin-bottom:32px;\n  filter:drop-shadow(0 0 40px rgba(232,76,43,0.45));\n  animation:gv-float 4s ease-in-out infinite;\n}\n@keyframes gv-float{\n  0%,100%{transform:translateY(0);}\n  50%{transform:translateY(-10px);}\n}\n.gv-hero__eyebrow{\n  font-size:.65rem;\n  letter-spacing:.35em;\n  text-transform:uppercase;\n  color:rgba(245,244,240,0.5);\n  font-weight:600;\n  margin:0 0 16px;\n}\n.gv-hero__heading{\n  font-size:clamp(2.8rem,7.5vw,7rem);\n  font-weight:800;\n  line-height:0.93;\n  letter-spacing:-0.03em;\n  text-transform:uppercase;\n  color:#f5f4f0;\n  margin:0 0 40px;\n}\n.gv-hero__btn{\n  display:inline-block;\n  padding:16px 40px;\n  font-size:.7rem;\n  letter-spacing:.2em;\n  text-transform:uppercase;\n  font-weight:700;\n  color:#fff;\n  background:transparent;\n  border:1px solid rgba(245,244,240,0.35);\n  border-radius:2px;\n  text-decoration:none;\n  transition:background .25s ease,border-color .25s ease,transform .2s ease;\n}\n.gv-hero__btn:hover{\n  background:#E84C2B;\n  border-color:#E84C2B;\n  transform:translateY(-2px);\n}\n.gv-hero__scroll{\n  position:absolute;\n  bottom:28px;left:50%;\n  transform:translateX(-50%);\n  z-index:2;\n  display:flex;flex-direction:column;align-items:center;gap:8px;\n}\n.gv-hero__scroll span{\n  font-size:.58rem;letter-spacing:.25em;text-transform:uppercase;\n  color:rgba(245,244,240,0.3);\n}\n.gv-hero__scroll-line{\n  width:1px;height:40px;\n  background:linear-gradient(to bottom,rgba(245,244,240,0.4),transparent);\n  animation:gv-scroll-drop 1.6s ease-in-out infinite;\n}\n@keyframes gv-scroll-drop{\n  0%{transform:scaleY(0);transform-origin:top;}\n  50%{transform:scaleY(1);transform-origin:top;}\n  51%{transform:scaleY(1);transform-origin:bottom;}\n  100%{transform:scaleY(0);transform-origin:bottom;}\n}\n@media(max-width:749px){\n  .gv-hero__heading{font-size:clamp(2.2rem,10vw,3.8rem);}\n  .gv-hero__icon{width:120px;height:120px;}\n}\n</style>\n\n<div class=\"gv-hero\">\n  <div class=\"gv-hero__bg\">\n    <img\n      src=\"{{ 'heroimg.png' | asset_url }}\"\n      alt=\"\"\n      class=\"gv-hero__bg-img\"\n      loading=\"eager\"\n      fetchpriority=\"high\"\n    >\n  </div>\n\n  <div class=\"gv-hero__body\">\n    <img\n      src=\"{{ 'Logo.png' | asset_url }}\"\n      alt=\"Ghosts Vintage\"\n      class=\"gv-hero__icon\"\n      width=\"160\"\n      height=\"160\"\n      loading=\"eager\"\n    >\n    <p class=\"gv-hero__eyebrow\">New Arrivals</p>\n    <h1 class=\"gv-hero__heading\">Vintage clothing, decor, & more!<br></h1>\n    <a href=\"/collections/all\" class=\"gv-hero__btn\">Shop the Collection</a>\n  </div>\n\n  <div class=\"gv-hero__scroll\" aria-hidden=\"true\">\n    <span>Scroll</span>\n    <div class=\"gv-hero__scroll-line\"></div>\n  </div>\n</div>",
