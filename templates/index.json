        "custom_liquid": "<style>\n.cp-hero{position:relative;min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;overflow:hidden;background:#080808}\n.cp-hero__bg{position:absolute;inset:0;z-index:0}\n.cp-hero__bg-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:-1;filter:brightness(0.38) saturate(0.72);transform:scale(1.06);animation:cp-bgzoom 22s ease-in-out infinite alternate}\n@keyframes cp-bgzoom{from{transform:scale(1.06)}to{transform:scale(1.14)}}\n.cp-hero__gradient{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(8,8,8,0.18) 0%,rgba(8,8,8,0.08) 25%,rgba(8,8,8,0.62) 65%,#080808 100%);z-index:0}\n.cp-hero__vignette{position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 40%,rgba(8,8,8,0.55) 100%);z-index:0}\n.cp-hero__body{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 24px;animation:cp-body-in 1.1s cubic-bezier(0,0,0.18,1) 0.15s both}\n@keyframes cp-body-in{from{opacity:0;transform:translateY(36px)}to{opacity:1;transform:translateY(0)}}\n.cp-hero__logo{width:min(280px,62vw);height:auto;object-fit:contain;margin-bottom:32px;filter:drop-shadow(0 0 60px rgba(201,122,26,0.55)) drop-shadow(0 0 20px rgba(232,76,43,0.25));animation:cp-float 5.5s ease-in-out infinite}\n@keyframes cp-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-9px)}}\n.cp-hero__eyebrow{font-size:.6rem;letter-spacing:.4em;text-transform:uppercase;color:#C97A1A;font-weight:700;margin:0 0 20px;display:flex;align-items:center;gap:14px}\n.cp-hero__eyebrow::before,.cp-hero__eyebrow::after{content:'';display:inline-block;width:30px;height:1px;background:rgba(201,122,26,0.45)}\n.cp-hero__heading{font-size:clamp(2.6rem,7.5vw,7rem);font-weight:900;line-height:.88;letter-spacing:-.04em;text-transform:uppercase;color:#f5f4f0;margin:0 0 14px}\n.cp-hero__heading span{color:#C97A1A;display:block;font-size:.5em;letter