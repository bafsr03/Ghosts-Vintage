    "three_pillars": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n.gv-pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;width:100%}\n@media(max-width:749px){.gv-pillars{grid-template-columns:1fr}}\n.gv-pillar{position:relative;aspect-ratio:3/4;overflow:hidden;background:#111}\n.gv-pillar__img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .7s cubic-bezier(0,0,.18,1);filter:brightness(.55)}\n.gv-pillar:hover .gv-pillar__img{transform:scale(1.06);filter:brightness(.4)}\n.gv-pillar__body{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:32px 28px}\n.gv-pillar__num{font-size:.65rem;letter-spacing:.28em;text-transform:uppercase;color:#E84C2B;font-weight:700;margin-bottom:10px}\n.gv-pillar__title{font-size:1.6rem;font-weight:800;text-transform:uppercase;color:#f5f4f0;letter-spacing:.02em;margin:0 0 10px}\n.gv-pillar__desc{font-size:.78rem;line-height:1.55;color:rgba(245,244,240,.65);margin:0;max-width:260px}\n</style>\n<div class=\"gv-pillars\">\n  <div class=\"gv-pillar\">\n    <img src=\"https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80\" alt=\"The Hunt\" class=\"gv-pillar__img\">\n    <div class=\"gv-pillar__body\">\n      <span class=\"gv-pillar__num\">01</span>\n      <h3 class=\"gv-pillar__title\">The Hunt</h3>\n      <p class=\"gv-pillar__desc\">We scour estate sales, markets and closets across the country for the pieces worth saving.</p>\n    </div>\n  </div>\n  <div class=\"gv-pillar\">\n    <img src=\"https://images.unsplash.com/photo-1445205170230-053b83016050?w=600&q=80\" alt=\"The Find\" class=\"gv-pillar__img\">\n    <div class=\"gv-pillar__body\">\n      <span class=\"gv-pillar__num\">02</span>\n      <h3 class=\"gv-pillar__title\">The Find</h3>\n      <p class=\"gv-pillar__desc\">Every item is hand-selected, authenticated and restored to its original glory — or better.</p>\n    </div>\n  </div>\n  <div class=\"gv-pillar\">\n    <img src=\"https://images.unsplash.com/photo-1489987707025-afc232f7ea0f?w=600&q=80\" alt=\"The Haunt\" class=\"gv-pillar__img\">\n    <div class=\"gv-pillar__body\">\n      <span class=\"gv-pillar__num\">03</span>\n      <h3 class=\"gv-pillar__title\">The Haunt</h3>\n      <p class=\"gv-pillar__desc\">Your wardrobe becomes a curated archive. One-of-a-kind pieces, worn by legends, now yours.</p>\n    </div>\n  </div>\n</div>",
        "color_scheme": "scheme-1",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "newsletter_section": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n.gv-newsletter{text-align:center;max-width:680px;margin:0 auto;padding:0 24px}\n.gv-newsletter__label{display:block;font-size:.65rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(245,244,240,.5);margin-bottom:20px}\n.gv-newsletter__title{font-size:clamp(2.2rem,5vw,4rem);font-weight:800;text-transform:uppercase;letter-spacing:-.01em;color:#f5f4f0;margin:0 0 10px}\n.gv-newsletter__title span{color:#E84C2B}\n.gv-newsletter__sub{font-size:.82rem;color:rgba(245,244,240,.5);letter-spacing:.06em;text-transform:uppercase;margin-bottom:40px}\n.gv-newsletter__form{display:flex;gap:0;max-width:480px;margin:0 auto;border:1px solid rgba(245,244,240,.18);border-radius:2px;overflow:hidden}\n.gv-newsletter__input{flex:1;background:transparent;border:none;color:#f5f4f0;font-size:.82rem;letter-spacing:.08em;padding:16px 20px;outline:none}\n.gv-newsletter__input::placeholder{color:rgba(245,244,240,.35);text-transform:uppercase;letter-spacing:.1em}\n.gv-newsletter__btn{background:#E84C2B;color:#fff;border:none;font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;font-weight:700;padding:16px 24px;cursor:pointer;transition:background .2s ease;white-space:nowrap}\n.gv-newsletter__btn:hover{background:#c73d21}\n.gv-divider-line{width:80px;height:2px;background:#E84C2B;margin:0 auto 40px;display:block}\n</style>\n<div class=\"gv-newsletter\">\n  <span class=\"gv-newsletter__label\">Stay in the loop</span>\n  <h2 class=\"gv-newsletter__title\">JOIN THE <span>HAUNT</span></h2>\n  <p class=\"gv-newsletter__sub\">New drops. Rare finds. First access.</p>\n  <span class=\"gv-divider-line\"></span>\n  <form class=\"gv-newsletter__form\" action=\"/contact#contact_form\" method=\"post\" accept-charset=\"UTF-8\">\n    <input type=\"hidden\" name=\"form_type\" value=\"customer\">\n    <input type=\"hidden\" name=\"utf8\" value=\"✓\">\n    <input type=\"hidden\" name=\"contact[tags]\" value=\"newsletter\">\n    <input class=\"gv-newsletter__input\" type=\"email\" name=\"contact[email]\" placeholder=\"Your email address\" required>\n    <button class=\"gv-newsletter__btn\" type=\"submit\">Subscribe</button>\n  </form>\n</div>",
        "color_scheme": "scheme-1",
        "section_width": "page-width",
        "padding-block-start": 100,
        "padding-block-end": 100
      }
    },
    "service_cta": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<style>\n.gv-service{text-align:center;position:relative;overflow:hidden}\n.gv-service__bg{position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1523381210434-271e8be1f52b?w=1400&q=80') center/cover no-repeat;filter:brightness(.25);z-index:0}\n.gv-service__inner{position:relative;z-index:1;max-width:800px;margin:0 auto;padding:0 24px}\n.gv-service__label{display:block;font-size:.65rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(245,244,240,.5);margin-bottom:20px}\n.gv-service__title{font-size:clamp(2.8rem,7vw,6rem);font-weight:800;text-transform:uppercase;letter-spacing:-.02em;color:#f5f4f0;margin:0 0 20px;line-height:1}\n.gv-service__desc{font-size:.88rem;line-height:1.7;color:rgba(245,244,240,.6);margin:0 0 44px;max-width:500px;margin-left:auto;margin-right:auto}\n.gv-service__btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}\n.gv-service__btn{display:inline-block;padding:14px 32px;font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;font-weight:700;text-decoration:none;border-radius:2px;transition:all .25s ease}\n.gv-service__btn--primary{background:#E84C2B;color:#fff;border:1px solid #E84C2B}\n.gv-service__btn--primary:hover{background:#c73d21;border-color:#c73d21}\n.gv-service__btn--secondary{background:transparent;color:#f5f4f0;border:1px solid rgba(245,244,240,.3)}\n.gv-service__btn--secondary:hover{background:rgba(245,244,240,.08);border-color:rgba(245,244,240,.5)}\n</style>\n<div class=\"gv-service\">\n  <div class=\"gv-service__bg\"></div>\n  <div class=\"gv-service__inner\">\n    <span class=\"gv-service__label\">Need something special?</span>\n    <h2 class=\"gv-service__title\">AT YOUR<br>SERVICE</h2>\n    <p class=\"gv-service__desc\">Personal styling. Custom sourcing. Private appointments. Whatever you need — we make vintage work for you.</p>\n    <div class=\"gv-service__btns\">\n      <a href=\"/pages/contact\" class=\"gv-service__btn gv-service__btn--primary\">Contact Us</a>\n      <a href=\"/collections/all\" class=\"gv-service__btn gv-service__btn--secondary\">Shop Now</a>\n    </div>\n  </div>\n</div>",
